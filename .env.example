# AWS
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-northeast-2

# ECR
ECR_REGISTRY=123456789012.dkr.ecr.ap-northeast-2.amazonaws.com
ECR_REPOSITORY=bandmate

# EC2
EC2_HOST=ec2-xx-xx-xx-xx.ap-northeast-2.compute.amazonaws.com
EC2_SSH_KEY=-----BEGIN RSA PRIVATE KEY-----...

# RDS (MySQL)
DB_HOST=bandmate.xxxxxx.ap-northeast-2.rds.amazonaws.com
DB_PORT=3306
DB_USERNAME=bandmate
DB_PASSWORD=your-strong-password

# JWT (최소 32자 이상)
JWT_SECRET=your-jwt-secret-key-must-be-at-least-32-characters-long
